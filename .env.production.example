# Production Environment Configuration for Frontend
# Copy this to .env.production and fill in your actual values
# OR set these as environment variables in Vercel/Railway

# API Configuration (Your Backend URL)
VITE_API_URL=https://your-backend-domain.railway.app/api/v1

# Razorpay Configuration (LIVE MODE - CRITICAL!)
# Get from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_live_YOUR_LIVE_KEY_ID

# Stripe Configuration (Optional - if using Stripe)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_live_publishable_key

# Analytics
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# Sentry Error Tracking
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
VITE_SENTRY_ENVIRONMENT=production

# Feature Flags
VITE_ENABLE_CHAT=true
VITE_ENABLE_VIDEO_CALLS=true
VITE_ENABLE_GROUP_SESSIONS=true

# Application Info
VITE_APP_NAME=Serene Wellbeing Hub
VITE_APP_VERSION=1.0.0
VITE_SUPPORT_EMAIL=support@serene-wellbeing.com

# Debug Mode (should be false in production)
VITE_DEBUG=false
